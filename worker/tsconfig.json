{
  "compilerOptions": {
    "target":           "ES2022",
    "module":           "ES2022",
    "moduleResolution": "bundler",
    "lib":              ["ES2022"],
    "strict":           true,
    "noUncheckedIndexedAccess": true,
    "types":            ["@cloudflare/workers-types"],
    "outDir":           "./dist",
    "rootDir":          "./src",
    "declaration":      true,
    "skipLibCheck":     true
  },
  "include": ["src/**/*"]
}
