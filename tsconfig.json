{
  "compilerOptions": {
    "target":           "ES2022",
    "module":           "ES2022",
    "moduleResolution": "bundler",
    "lib":              ["ES2022", "DOM", "DOM.Iterable"],
    "types":            ["vite/client"],
    "strict":           true,
    "noUncheckedIndexedAccess": true,
    "useDefineForClassFields": true,
    "skipLibCheck":     true,
    "noEmit":           true
  },
  "include": ["src/**/*", "vite.config.ts"]
}
